{
    "beacons_file": "known_beacons.json",
    "operators_file": "operators.json",
    "server": {
        "host": "localhost",
        "port": 6767,
        "ssl_cert": "ssl/cert.pem",
        "ssl_key": "ssl/key.pem",
        "session_timeout_minutes": 60,
        "custom_headers": [
            {"name": "X-Powered-By", "value": "Pandragon"},
            {"name": "X-Request-ID", "value": "UhhReplaceMe"},

            {"name": "Cache-Control", "value": "no-transform"}
        ]
    },
    "beacon": {
        "bof_directory": "bofs",
        "download_directory": "pandragon_downloads/"
    },
    "listeners": [
        {
            "name": "operator_https",
            "protocol": "https",
            "host": "0.0.0.0",
            "port": 6767,
            "ssl_cert": "ssl/cert.pem",
            "ssl_key": "ssl/key.pem",
            "primary": true,
            "beacon_enabled": true
        },
        {
            "name": "beacon_https",
            "protocol": "http",
            "host": "0.0.0.0",
            "port": 8080,
            "primary": false,
            "beacon_enabled": true
        },
        {
            "name": "beacon_tcp",
            "protocol": "tcp",
            "host": "127.0.0.1",
            "port": 6868,
            "primary": false,
            "beacon_enabled": true
        }
    ],
    "security": {
        "max_payload_size": 10485760
    },
    "operator_routes": {
        "websocket": {"path": "/ws"}
    },
    "logging": {
        "level": "INFO",
        "target": "pandragon.log"
    },
    "audit": {
        "enabled": false,
        "target": "pandragon_audit.log"
    }
}
