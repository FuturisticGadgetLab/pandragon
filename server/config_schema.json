{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "pandragon-server-config.json",
    "title": "Pandragon Teamserver Configuration",
    "description": "Configuration schema for the Pandragon C2 teamserver",
    "type": "object",
    "properties": {
        "server": {
            "type": "object",
            "description": "Server-wide settings. Used to build a legacy listener when the listeners array is absent or empty.",
            "properties": {
                "host": {
                    "type": "string",
                    "description": "Bind address",
                    "minLength": 1,
                    "maxLength": 255
                },
                "port": {
                    "type": "integer",
                    "description": "Bind port",
                    "minimum": 1,
                    "maximum": 65535
                },
                "ssl_cert": {
                    "type": "string",
                    "description": "Path to SSL certificate file",
                    "minLength": 1,
                    "maxLength": 4096
                },
                "ssl_key": {
                    "type": "string",
                    "description": "Path to SSL key file",
                    "minLength": 1,
                    "maxLength": 4096
                },
                "session_timeout_minutes": {
                    "type": "integer",
                    "description": "Operator session idle timeout in minutes",
                    "minimum": 1,
                    "maximum": 1440
                },
                "custom_headers": {
                    "type": "array",
                    "description": "Custom HTTP headers added to every server response",
                    "maxItems": 255,
                    "items": {
                        "type": "object",
                        "required": ["name", "value"],
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "HTTP header name",
                                "minLength": 1,
                                "maxLength": 256
                            },
                            "value": {
                                "type": "string",
                                "description": "HTTP header value",
                                "maxLength": 1024
                            }
                        },
                        "additionalProperties": false
                    }
                }
            },
            "additionalProperties": false
        },
        "beacon": {
            "type": "object",
            "description": "Beacon defaults applied to all beacons",
            "properties": {
                "bof_directory": {
                    "type": "string",
                    "description": "Directory containing Beacon Object File binaries",
                    "minLength": 1,
                    "maxLength": 4096
                },
                "download_directory": {
                    "type": "string",
                    "description": "Directory where downloaded files from beacons are assembled",
                    "minLength": 1,
                    "maxLength": 4096
                }
            },
            "additionalProperties": false
        },
        "listeners": {
            "type": "array",
            "description": "List of listener definitions for beacon communication. If absent or empty, a single legacy listener is synthesised from the server.* keys.",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Display name for the listener",
                        "minLength": 1,
                        "maxLength": 256
                    },
                    "protocol": {
                        "type": "string",
                        "enum": ["http", "https", "tcp"],
                        "description": "Transport protocol"
                    },
                    "host": {
                        "type": "string",
                        "description": "Bind address for this listener",
                        "minLength": 1,
                        "maxLength": 255
                    },
                    "port": {
                        "type": "integer",
                        "description": "Bind port for this listener",
                        "minimum": 1,
                        "maximum": 65535
                    },
                    "ssl_cert": {
                        "type": "string",
                        "description": "Path to SSL certificate file (required when protocol is https)",
                        "minLength": 1,
                        "maxLength": 4096
                    },
                    "ssl_key": {
                        "type": "string",
                        "description": "Path to SSL key file (required when protocol is https)",
                        "minLength": 1,
                        "maxLength": 4096
                    },
                    "primary": {
                        "type": "boolean",
                        "description": "Marks this as the primary listener. The primary listener hosts the operator WebSocket endpoint. If no primary is found among HTTPS listeners, the first HTTPS listener is auto-promoted."
                    },
                    "beacon_enabled": {
                        "type": "boolean",
                        "description": "Whether beacon HTTP routes are registered on this listener"
                    }
                },
                "additionalProperties": false
            }
        },
        "beacons_file": {
            "type": "string",
            "description": "Path to the JSON file containing pre-registered beacon credentials",
            "minLength": 1,
            "maxLength": 4096
        },
        "operators_file": {
            "type": "string",
            "description": "Path to the JSON file containing operator credentials",
            "minLength": 1,
            "maxLength": 4096
        },
        "logging": {
            "type": "object",
            "description": "Application logging configuration",
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "description": "Master switch for application logging"
                },
                "level": {
                    "type": "string",
                    "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"],
                    "description": "Log level"
                },
                "target": {
                    "type": "string",
                    "description": "File path for rotating file log. If empty, logs go only to stderr.",
                    "maxLength": 4096
                }
            },
            "additionalProperties": false
        },
        "audit": {
            "type": "object",
            "description": "Security audit logging configuration",
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "description": "Master switch for security audit logging"
                },
                "target": {
                    "type": "string",
                    "description": "File path for the rotating audit log",
                    "minLength": 1,
                    "maxLength": 4096
                }
            },
            "additionalProperties": false
        },
        "operator_routes": {
            "type": "object",
            "description": "Operator WebSocket route configuration",
            "properties": {
                "websocket": {
                    "type": "object",
                    "description": "WebSocket endpoint configuration",
                    "properties": {
                        "path": {
                            "type": "string",
                            "description": "URL path for the operator WebSocket endpoint",
                            "minLength": 1,
                            "maxLength": 256
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "security": {
            "type": "object",
            "description": "Security-related settings",
            "properties": {
                "max_payload_size": {
                    "type": "integer",
                    "description": "Maximum allowed payload size in bytes",
                    "minimum": 1024,
                    "maximum": 1073741824
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}
