                    "maxItems": 255,
                    "items": {
                        "type": "object",
                        "required": ["name", "value"],
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "HTTP header name",
                                "minLength": 1,
                                "maxLength": 255
                            },
                            "value": {
                                "type": "string",
                                "description": "HTTP header value",
                                "maxLength": 255
                            }
                        }
                    }
                },
                "payload_location": {
                    "type": "object",
                    "required": ["type"],
                    "description": "Where to place the (wrapped) payload in the GET request",
                    "properties": {
                        "type": {
                            "type": "string",
                            "enum": ["query_param", "path"],
                            "description": "Location type: query_param (?q=PAYLOAD) or path (/PREFIXPAYLOADSUFFIX)"
                        },
                        "param_name": {
                            "type": "string",
                            "description": "Query parameter name (for query_param type)",
                            "maxLength": 255
                        },
                        "path_prefix": {
                            "type": "string",
                            "description": "Prefix to add before payload in path mode",
                            "maxLength": 255
                        },
                        "path_suffix": {
                            "type": "string",
                            "description": "Suffix to add after payload in path mode (e.g., .png)",
                            "maxLength": 255
                        },
                        "body_content_type": {
                            "type": "string",
                            "description": "Content-Type (reserved)",
                            "enum": ["text/plain", "application/octet-stream"]
                        },
                        "cookie_name": {
                            "type": "string",
                            "description": "Cookie name for request-side Cookie header injection",
                            "maxLength": 255
                        }
                    },
                    "additionalProperties": false
                }
            }
        },
        "submit_malleable_config": {
            "type": "object",
            "description": "Global submit (POST) malleable config. Used when a channel has no per-channel submit_malleable_config.",
            "properties": {
                "wrapper": {
                    "type": "object",
                    "description": "Prefix/suffix wrapper for base64url-encoded submit payloads",
