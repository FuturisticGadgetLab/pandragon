        "work_hours": {
            "type": "object",
            "description": "UTC-based work hours configuration",
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "description": "Enable work hours enforcement"
                },
                "start_hour": {
                    "type": "integer",
                    "description": "Start hour in UTC (0-23)",
                    "minimum": 0,
                    "maximum": 23
                },
                "start_minute": {
                    "type": "integer",
                    "description": "Start minute (0-59)",
                    "minimum": 0,
                    "maximum": 59
                },
                "end_hour": {
                    "type": "integer",
                    "description": "End hour in UTC (0-23)",
                    "minimum": 0,
                    "maximum": 23
                },
                "end_minute": {
                    "type": "integer",
                    "description": "End minute (0-59)",
                    "minimum": 0,
                    "maximum": 59
                },
                "insomnia": {
                    "type": "boolean",
                    "description": "If true: wake up normally but skip check-in. If false: sleep until work hours start."
