                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "HTTP header name",
                                "minLength": 1,
                                "maxLength": 255
                            },
                            "value": {
                                "type": "string",
                                "description": "HTTP header value",
                                "maxLength": 255
                            }
                        }
                    }
                },
                "payload_location": {
                    "type": "object",
                    "required": ["type"],
                    "description": "Where to place the (wrapped) payload in the POST request",
                    "properties": {
                        "type": {
                            "type": "string",
                            "enum": ["body", "query_param", "path"],
                            "description": "Location type: body (POST data), query_param, or path"
                        },
                        "param_name": {
                            "type": "string",
                            "description": "Query parameter name (for query_param type)",
                            "maxLength": 255
                        },
                        "path_prefix": {
                            "type": "string",
                            "description": "Prefix to add before payload in path mode",
                            "maxLength": 255
                        },
                        "path_suffix": {
                            "type": "string",
                            "description": "Suffix to add after payload in path mode",
                            "maxLength": 255
                        },
                        "body_content_type": {
                            "type": "string",
                            "description": "Content-Type for body mode",
                            "enum": ["text/plain", "application/octet-stream"]
                        },
                        "cookie_name": {
                            "type": "string",
                            "description": "Cookie name for request-side Cookie header injection",
